{
  "name": "@glypher/export-pdf",
  "version": "0.0.1",
  "description": "Export a Glypher document to a PDF file (basic text flow).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": { "pdf-lib": "^1.17.1" },
  "peerDependencies": { "@glypher/core": "^0.0.1" },
  "devDependencies": {
    "@glypher/core": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
