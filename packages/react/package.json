{
  "name": "@glypher/react",
  "version": "0.0.1",
  "description": "React bindings for Glypher.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react --external react-dom",
    "dev": "tsup src/index.tsx --format esm,cjs --dts --watch --external react --external react-dom",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@glypher/core": "^0.0.1",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@glypher/core": "workspace:*",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "jsdom": "^29.1.1",
    "vitest": "^1.6.0"
  }
}
