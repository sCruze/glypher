{
  "name": "@glypher/vue",
  "version": "0.0.1",
  "description": "Vue 3 bindings for Glypher.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external vue",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external vue",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@glypher/core": "^0.0.1",
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@glypher/core": "workspace:*",
    "vue": "^3.4.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
