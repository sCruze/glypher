{
  "name": "glypher",
  "private": true,
  "version": "0.0.0",
  "description": "Glypher — rich text editor library (monorepo root).",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run --if-present build",
    "dev": "pnpm -r --parallel --filter './packages/*' run --if-present dev",
    "playground": "pnpm --filter @glypher/playground run dev",
    "docs": "pnpm --filter @glypher/docs run dev",
    "test": "pnpm -r --filter './packages/*' run --if-present test",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx}\"",
    "typecheck": "pnpm -r run --if-present typecheck",
    "clean": "pnpm -r run --if-present clean && rm -rf node_modules",
    "test:e2e": "pnpm --filter @glypher/playground run test:e2e",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:dry-run": "pnpm -r --filter './packages/*' publish --dry-run --access public --no-git-checks",
    "release:gem": "bash scripts/publish-gem.sh",
    "release:gem:dry-run": "bash scripts/publish-gem.sh --dry-run",
    "version:status": "node scripts/bump-version.mjs status",
    "version:gem": "node scripts/bump-version.mjs gem",
    "check:lockfile": "node scripts/check-lockfile-sync.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.12.7",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ]
}
